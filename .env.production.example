# Copy this file to .env.production and fill values before starting in production
# Required
JWT_SECRET=your-strong-jwt-secret-here
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public&connection_limit=1&pool_timeout=20
FRONTEND_URL=https://your-frontend.example.com
PORT=5000

# Optional
STARTUP_DB_ATTEMPTS=5
STARTUP_DB_RETRY_MS=5000
